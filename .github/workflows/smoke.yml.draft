# ============================================================================
# DRAFT — NOT ACTIVE. GitHub Actions only runs *.yml / *.yaml under
# .github/workflows/, so this ".yml.draft" file never executes. It is a
# review-ready draft of the per-push smoke conformance gate (CI plan P1) — the
# piece that actually closes elevm's conformance-in-CI gap.
#
# UNVERIFIED: no GitHub Actions run has exercised this. To activate:
#   git mv smoke.yml.draft smoke.yml     # (or fold the `smoke` job into ci.yml)
# then push and OBSERVE two runs before trusting it:
#   1. fixture-cache MISS — bootstrap clones the corpus; confirm the sha/commit
#      pins in its log, and that --smoke matches baseline-smoke.txt.
#   2. fixture-cache HIT — bootstrap no-ops; run is fast.
#
# Verify-on-first-run checklist:
#   - lean-action restores the mathlib cache (grep the run log for "cache").
#   - `lake build` produced .lake/build/bin/elevm (check.sh --no-build needs it).
#   - the actions/cache key/path actually HIT on run 2.
#   - the cached execution-specs+tests checkout (it includes .git) stays under
#     the 10 GB/repo cache ceiling; if not, narrow the cached path to the
#     BlockchainTests leaf.
#   - timeout-minutes sits comfortably above the observed wall time; tighten it.
# ============================================================================
name: smoke

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

env:
  # bootstrap_legacy.py installs execution-specs here (its default is
  # ~/execution-specs); pinned into the workspace so actions/cache can hold it.
  EELS_ROOT: ${{ github.workspace }}/.fixtures/execution-specs

jobs:
  smoke:
    runs-on: ubuntu-24.04
    # Basis: ~9 min smoke reference (dominated by one ~6.6 min vmPerformance
    # file) + Lean build + first-run provisioning, with slack. Re-measure on the
    # first real run and tighten.
    timeout-minutes: 40

    steps:
      - uses: actions/checkout@v6

      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      # Builds elevm (elaborating every #guard) and leaves the executable at
      # .lake/build/bin/elevm for check.sh --no-build.
      - uses: leanprover/lean-action@v1

      - name: Cache legacy fixture corpus
        uses: actions/cache@v4
        with:
          path: ${{ env.EELS_ROOT }}
          key: legacy-fixtures-${{ hashFiles('scripts/sources.json') }}

      # Idempotent: on a cache hit the checkout already matches the manifest and
      # this is a fast no-op; on a miss it clones execution-specs + the nested
      # ethereum/tests + LegacyTests at their pinned commits (sha-verified).
      - name: Provision legacy fixtures
        run: python3 scripts/bootstrap_legacy.py --execution-specs "$EELS_ROOT"

      # ELEVM_TIMEOUT is left at check.sh's 1800 s default: it is a hang
      # detector, not a per-file budget, and the slowest smoke file (~395 s
      # reference) has ample headroom even on a slower hosted runner.
      - name: Smoke conformance gate (check.sh --smoke)
        run: |
          ELEVM_FIXTURES="$EELS_ROOT/tests/fixtures/ethereum_tests/BlockchainTests" \
            scripts/check.sh --smoke --no-build
