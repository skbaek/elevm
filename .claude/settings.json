{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "mcp__lean-lsp-mcp"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/permit.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
